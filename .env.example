# SnapBack VS Code Extension Environment Configuration
# VS Code extension-specific environment variables

# =============================================================================
# EXTENSION CONFIGURATION
# =============================================================================

# Extension Basic Settings
EXTENSION_NAME=snapback-vscode
EXTENSION_VERSION=0.1.0
EXTENSION_PUBLISHER="Marcelle Labs"

# Activation Settings
AUTO_ACTIVATE=true
SHOW_WELCOME_ON_FIRST_INSTALL=true
ACTIVATION_EVENTS=onStartupFinished

# =============================================================================
# VS CODE INTEGRATION
# =============================================================================

# VS Code API Settings
VSCODE_API_VERSION=1.75.0
CONTRIBUTE_COMMANDS=true
CONTRIBUTE_VIEWS=true
CONTRIBUTE_MENUS=true

# Extension Host Settings
EXTENSION_HOST_TIMEOUT_MS=30000
EXTENSION_HOST_MEMORY_LIMIT_MB=256

# =============================================================================
# USER INTERFACE CONFIGURATION
# =============================================================================

# Status Bar
STATUS_BAR_ENABLED=true
STATUS_BAR_PRIORITY=100
STATUS_BAR_ALIGNMENT=left

# Activity Bar
ACTIVITY_BAR_VIEW_ENABLED=true
ACTIVITY_BAR_ICON=shield
ACTIVITY_BAR_TITLE=SnapBack

# Sidebar Views
SNAPSHOT_TIMELINE_ENABLED=true
RISK_DASHBOARD_ENABLED=true
FILE_PROTECTION_ENABLED=true
WELCOME_VIEW_ENABLED=true

# =============================================================================
# NOTIFICATIONS CONFIGURATION
# =============================================================================

# Notification Settings
NOTIFICATIONS_ENABLED=true
NOTIFICATION_LEVEL=info
SHOW_PROGRESS_NOTIFICATIONS=true

# Notification Types
SHOW_SUCCESS_NOTIFICATIONS=true
SHOW_WARNING_NOTIFICATIONS=true
SHOW_ERROR_NOTIFICATIONS=true
SHOW_INFO_NOTIFICATIONS=false

# =============================================================================
# COMMAND CONFIGURATION
# =============================================================================

# Command Settings
COMMANDS_ENABLED=true
COMMAND_TIMEOUT_MS=30000
SHOW_COMMAND_PROGRESS=true

# Command Visibility
CONTEXT_MENU_COMMANDS=true
COMMAND_PALETTE_COMMANDS=true
EDITOR_COMMANDS=true

# =============================================================================
# FILE PROTECTION SETTINGS
# =============================================================================

# Unified Configuration System
SNAPBACKRC_ENABLED=true
CONFIG_MIGRATION_ENABLED=true
AUTO_PROTECT_SNAPBACKRC=true

# File Protection
AUTO_PROTECT_FILES=false
PROTECTED_FILE_EXTENSIONS=.env,.key,.pem,.cert,.json
PROTECTION_NOTIFICATION_LEVEL=warning

# File Watching
FILE_WATCHER_ENABLED=true
WATCH_EXCLUDED_PATTERNS=node_modules/**,dist/**,.git/**

# =============================================================================
# WORKSPACE CONFIGURATION
# =============================================================================

# Workspace Settings
WORKSPACE_AUTO_DETECTION=true
MULTI_ROOT_WORKSPACE_SUPPORT=true
WORKSPACE_TRUST_REQUIRED=false

# Project Settings
PROJECT_CONFIG_FILE=.snapbackrc
INHERIT_WORKSPACE_SETTINGS=true

# =============================================================================
# INTEGRATION SETTINGS
# =============================================================================

# Core Package Integration
CORE_INTEGRATION_ENABLED=true
STORAGE_INTEGRATION_ENABLED=true

# Git Integration
GIT_INTEGRATION_ENABLED=true
GIT_AUTO_SNAPSHOT_ON_COMMIT=false
GIT_SHOW_BRANCH_PROTECTION=true

# Terminal Integration
TERMINAL_INTEGRATION_ENABLED=true
TERMINAL_COMMAND_PREFIX=snapback

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Performance Configuration
LAZY_LOADING_ENABLED=true
CACHE_ANALYSIS_RESULTS=true
DEBOUNCE_FILE_CHANGES_MS=300

# Resource Limits
MAX_ANALYSIS_FILE_SIZE_MB=10
MAX_CONCURRENT_ANALYSIS=2
ANALYSIS_TIMEOUT_MS=30000

# =============================================================================
# TELEMETRY CONFIGURATION
# =============================================================================

# Extension Telemetry
TELEMETRY_EXTENSION_ENABLED=true
TELEMETRY_TRACK_COMMANDS=true
TELEMETRY_TRACK_VIEWS=true
TELEMETRY_TRACK_ERRORS=true

# Usage Analytics
TRACK_FEATURE_USAGE=true
TRACK_PERFORMANCE_METRICS=false

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Development Mode
DEVELOPMENT_MODE=false
DEBUG_LOGGING=false
VERBOSE_OUTPUT=false

# Hot Reload
HOT_RELOAD_ENABLED=false
WATCH_SOURCE_FILES=false

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Security Configuration
SECURITY_SCANNING_ENABLED=true
SCAN_ON_FILE_SAVE=true
HIGHLIGHT_SECURITY_ISSUES=true

# Privacy Settings
COLLECT_ANONYMOUS_USAGE=true
RESPECT_TELEMETRY_SETTINGS=true

# =============================================================================
# ERROR HANDLING
# =============================================================================

# Error Configuration
SHOW_ERROR_STACK_TRACES=false
ERROR_REPORTING_ENABLED=false
GRACEFUL_ERROR_RECOVERY=true

# Error Notifications
SHOW_CRITICAL_ERRORS=true
SHOW_RECOVERABLE_ERRORS=false

# =============================================================================
# THEME & APPEARANCE
# =============================================================================

# Theme Settings
RESPECT_THEME_COLORS=true
CUSTOM_ICON_THEME=false
HIGH_CONTRAST_SUPPORT=true

# UI Customization
CUSTOM_CSS_ENABLED=false
ICON_SIZE=16px

# =============================================================================
# KEYBOARD SHORTCUTS
# =============================================================================

# Keybinding Settings
CUSTOM_KEYBINDINGS_ENABLED=true
KEYBINDING_SCOPE=editor

# Default Shortcuts
ANALYZE_RISK_SHORTCUT=ctrl+shift+a
CREATE_SNAPSHOT_SHORTCUT=ctrl+shift+c
SHOW_PROTECTION_STATUS_SHORTCUT=ctrl+shift+p

# =============================================================================
# WEBVIEW CONFIGURATION
# =============================================================================

# Webview Settings
WEBVIEW_ENABLED=true
WEBVIEW_SECURITY_POLICY=strict
WEBVIEW_ALLOW_SCRIPTS=true

# Content Security Policy
CSP_ENABLED=true
ALLOW_INLINE_STYLES=false
ALLOW_EXTERNAL_RESOURCES=false