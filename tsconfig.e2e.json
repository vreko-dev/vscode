{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "out",
		"rootDir": "src",
		"module": "commonjs",
		"moduleResolution": "node",
		"target": "ES2022",
		"lib": ["ES2022"],
		"sourceMap": true,
		"types": ["vscode", "mocha", "node"],
		"verbatimModuleSyntax": false
	},
	"include": ["src/test/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
