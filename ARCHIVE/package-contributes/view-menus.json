{
	"menus": {
		"scm/title": [
			{
				"command": "snapback.autoCheckpointBranch",
				"when": "snapback.isActive",
				"group": "navigation"
			}
		],
		"view/item/context": [
			{
				"command": "snapback.snapBack",
				"when": "view == snapback.main && viewItem == snapshot",
				"group": "inline@1"
			},
			{
				"command": "snapback.renameSnapshot",
				"when": "view == snapback.main && viewItem == snapshot",
				"group": "navigation@1"
			},
			{
				"command": "snapback.protectSnapshot",
				"when": "view == snapback.main && viewItem == snapshot && !snapshot.isProtected",
				"group": "protection@1"
			},
			{
				"command": "snapback.unprotectFile",
				"when": "view == snapback.main && viewItem == snapshot && snapshot.isProtected",
				"group": "protection@2"
			},
			{
				"command": "snapback.deleteSnapshot",
				"when": "view == snapback.main && viewItem == snapshot && !snapshot.isProtected",
				"group": "danger@1"
			},
			{
				"command": "snapback.unprotectAndDeleteSnapshot",
				"when": "view == snapback.main && viewItem == snapshot && snapshot.isProtected",
				"group": "danger@2"
			},
			{
				"command": "snapback.deleteOlderSnapshots",
				"when": "view == snapback.main && viewItem == snapshot",
				"group": "danger@3"
			},
			{
				"command": "snapback.setProtectionLevel",
				"when": "view == snapback.main && viewItem == protectedFile",
				"group": "inline@2"
			}
		]
	}
}
