{
	"submenus": [
		{
			"id": "snapback.protectionLevels",
			"label": "SnapBack: Set Protection Level",
			"icon": "$(shield)"
		}
	],
	"menus": {
		"explorer/context": [
			{
				"command": "snapback.createCheckpoint",
				"when": "snapback.isActive && !explorerResourceIsFolder",
				"group": "snapback@1"
			},
			{
				"command": "snapback.snapBack",
				"when": "snapback.isActive && !explorerResourceIsFolder",
				"group": "snapback@2"
			},
			{
				"submenu": "snapback.protectionLevels",
				"when": "snapback.isActive && !explorerResourceIsFolder",
				"group": "snapback@3"
			},
			{
				"command": "snapback.protectCurrentFile",
				"when": "snapback.isActive && !explorerResourceIsFolder",
				"group": "snapback@3"
			},
			{
				"command": "snapback.changeProtectionLevel",
				"when": "snapback.isActive && !explorerResourceIsFolder && snapback.fileProtected",
				"group": "snapback@4"
			},
			{
				"command": "snapback.unprotectFile",
				"when": "snapback.isActive && !explorerResourceIsFolder && snapback.fileProtected",
				"group": "snapback@5"
			},
			{
				"command": "snapback.compareWithCheckpoint",
				"when": "snapback.isActive && !explorerResourceIsFolder",
				"group": "snapback@6"
			}
		],
		"snapback.protectionLevels": [
			{
				"command": "snapback.setWatchLevel",
				"group": "levels@1"
			},
			{
				"command": "snapback.setWarnLevel",
				"group": "levels@2"
			},
			{
				"command": "snapback.setBlockLevel",
				"group": "levels@3"
			}
		],
		"editor/context": [
			{
				"submenu": "snapback.protectionLevels",
				"when": "snapback.isActive",
				"group": "snapback@1"
			},
			{
				"command": "snapback.protectCurrentFile",
				"when": "snapback.isActive",
				"group": "snapback@1"
			},
			{
				"command": "snapback.changeProtectionLevel",
				"when": "snapback.isActive && snapback.fileProtected",
				"group": "snapback@2"
			},
			{
				"command": "snapback.unprotectFile",
				"when": "snapback.isActive && snapback.fileProtected",
				"group": "snapback@3"
			},
			{
				"command": "snapback.createCheckpoint",
				"when": "snapback.isActive",
				"group": "snapback@4"
			}
		],
		"commandPalette": [
			{
				"command": "snapback.protectFile",
				"when": "snapback.isActive && editorFocus"
			},
			{
				"command": "snapback.protectCurrentFile",
				"when": "snapback.isActive && editorFocus"
			},
			{
				"command": "snapback.changeProtectionLevel",
				"when": "snapback.isActive && editorFocus"
			},
			{
				"command": "snapback.setWatchLevel",
				"when": "snapback.isActive && editorFocus"
			},
			{
				"command": "snapback.setWarnLevel",
				"when": "snapback.isActive && editorFocus"
			},
			{
				"command": "snapback.setBlockLevel",
				"when": "snapback.isActive && editorFocus"
			},
			{
				"command": "snapback.unprotectFile",
				"when": "snapback.isActive && snapback.fileProtected"
			},
			{
				"command": "snapback.compareWithCheckpoint",
				"when": "snapback.isActive"
			},
			{
				"command": "snapback.openProtectedFile",
				"when": "false"
			}
		],
		"view/item/context": [
			{
				"command": "snapback.openProtectedFile",
				"when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
				"group": "navigation@1"
			},
			{
				"submenu": "snapback.protectionLevels",
				"when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
				"group": "protection@1"
			},
			{
				"command": "snapback.changeProtectionLevel",
				"when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
				"group": "protection@2",
				"icon": "$(settings-gear)"
			},
			{
				"command": "snapback.createCheckpoint",
				"when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
				"group": "snapshot@1",
				"icon": "$(save)"
			},
			{
				"command": "snapback.snapBack",
				"when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
				"group": "snapshot@2",
				"icon": "$(history)"
			},
			{
				"command": "snapback.unprotectFile",
				"when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
				"group": "danger@1",
				"icon": "$(unlock)"
			},
			{
				"command": "snapback.unprotectFile",
				"when": "view == snapback.main && viewItem == snapback.item.protectedFile",
				"group": "danger@1",
				"icon": "$(unlock)"
			}
		],
		"view/title": [
			{
				"command": "snapback.refreshViews",
				"when": "view == snapback.protectedFiles",
				"group": "navigation@1",
				"icon": "$(refresh)"
			},
			{
				"command": "snapback.showAllProtectedFiles",
				"when": "view == snapback.protectedFiles",
				"group": "navigation@2",
				"icon": "$(list-tree)"
			}
		]
	}
}
