{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "SnapBack Configuration",
	"type": "object",
	"properties": {
		"protection": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["pattern", "level"],
				"properties": {
					"pattern": {
						"type": "string",
						"description": "Glob pattern that identifies files to protect"
					},
					"level": {
						"type": "string",
						"enum": ["watch", "warn", "block"],
						"description": "Protection level applied to matching files"
					},
					"reason": {
						"type": "string",
						"description": "Optional rationale displayed to the team"
					},
					"excludeFrom": {
						"type": "array",
						"items": { "type": "string" }
					},
					"autoCheckpoint": {
						"type": "boolean"
					},
					"debounce": {
						"type": "number",
						"minimum": 0
					}
				},
				"additionalProperties": false
			}
		},
		"ignore": {
			"type": "array",
			"items": {
				"type": "string"
			}
		},
		"settings": {
			"type": "object",
			"properties": {
				"maxSnapshots": {
					"type": "number",
					"minimum": 1
				},
				"compressionEnabled": {
					"type": "boolean"
				},
				"autoCheckpointInterval": {
					"type": "number",
					"minimum": 0
				},
				"notificationDuration": {
					"type": "number",
					"minimum": 0
				},
				"showStatusBarItem": {
					"type": "boolean"
				},
				"confirmRestore": {
					"type": "boolean"
				},
				"defaultProtectionLevel": {
					"type": "string",
					"enum": ["watch", "warn", "block"]
				},
				"protectionDebounce": {
					"type": "number",
					"minimum": 0
				},
				"snapshotLocation": {
					"type": "string"
				},
				"maxStorageSize": {
					"type": "number",
					"minimum": 0
				},
				"parallelOperations": {
					"type": "number",
					"minimum": 1
				},
				"enableCaching": {
					"type": "boolean"
				}
			},
			"additionalProperties": false
		},
		"policies": {
			"type": "object",
			"properties": {
				"requireCheckpointMessage": { "type": "boolean" },
				"enforceProtectionLevels": { "type": "boolean" },
				"allowOverrides": { "type": "boolean" },
				"minimumProtectionLevel": {
					"type": "string",
					"enum": ["watch", "warn", "block"]
				},
				"preventAccidentalCommit": { "type": "boolean" },
				"teamConfigUrl": { "type": "string" }
			},
			"additionalProperties": false
		},
		"hooks": {
			"type": "object",
			"properties": {
				"beforeSnapshot": { "type": "string" },
				"afterSnapshot": { "type": "string" },
				"beforeRestore": { "type": "string" },
				"afterRestore": { "type": "string" },
				"onProtectedFileChange": { "type": "string" }
			},
			"additionalProperties": false
		},
		"templates": {
			"type": "array",
			"items": {
				"type": "object",
				"required": ["name", "patterns"],
				"properties": {
					"name": { "type": "string" },
					"patterns": {
						"type": "array",
						"items": { "type": "string" }
					},
					"message": { "type": "string" },
					"tags": {
						"type": "array",
						"items": { "type": "string" }
					}
				},
				"additionalProperties": false
			}
		},
		"integrations": {
			"type": "object",
			"description": "🔌 External MCP integrations for enriched context (GitHub PRs, Sentry errors, Context7 docs)",
			"properties": {
				"enabled": {
					"type": "boolean",
					"default": true,
					"description": "Enable/disable all integrations globally"
				},
				"github": {
					"type": "object",
					"description": "📊 GitHub integration for PR context, change frequency, and file blame",
					"properties": {
						"enabled": {
							"type": "boolean",
							"default": false,
							"description": "Enable GitHub MCP integration"
						},
						"token": {
							"type": "string",
							"description": "GitHub personal access token (classic or fine-grained)"
						},
						"owner": {
							"type": "string",
							"description": "Repository owner/organization"
						},
						"repo": {
							"type": "string",
							"description": "Repository name"
						},
						"timeoutMs": {
							"type": "number",
							"default": 5000,
							"minimum": 1000,
							"description": "Request timeout in milliseconds"
						}
					},
					"additionalProperties": false
				},
				"context7": {
					"type": "object",
					"description": "📚 Context7 integration for API documentation validation and deprecation detection",
					"properties": {
						"enabled": {
							"type": "boolean",
							"default": false,
							"description": "Enable Context7 MCP integration"
						},
						"apiKey": {
							"type": "string",
							"description": "Context7 API key (get at https://context7.dev)"
						},
						"timeoutMs": {
							"type": "number",
							"default": 5000,
							"minimum": 1000,
							"description": "Request timeout in milliseconds"
						}
					},
					"additionalProperties": false
				},
				"sentry": {
					"type": "object",
					"description": "🐛 Sentry integration for production error context on modified files",
					"properties": {
						"enabled": {
							"type": "boolean",
							"default": false,
							"description": "Enable Sentry MCP integration"
						},
						"authToken": {
							"type": "string",
							"description": "Sentry auth token with project:read scope"
						},
						"organization": {
							"type": "string",
							"description": "Sentry organization slug"
						},
						"project": {
							"type": "string",
							"description": "Sentry project slug"
						},
						"timeoutMs": {
							"type": "number",
							"default": 5000,
							"minimum": 1000,
							"description": "Request timeout in milliseconds"
						}
					},
					"additionalProperties": false
				},
				"cache": {
					"type": "object",
					"description": "Cache configuration for integration responses",
					"properties": {
						"enabled": {
							"type": "boolean",
							"default": true,
							"description": "Enable response caching"
						},
						"githubTtlMs": {
							"type": "number",
							"default": 300000,
							"description": "GitHub cache TTL (5 minutes)"
						},
						"context7TtlMs": {
							"type": "number",
							"default": 1800000,
							"description": "Context7 cache TTL (30 minutes)"
						},
						"sentryTtlMs": {
							"type": "number",
							"default": 300000,
							"description": "Sentry cache TTL (5 minutes)"
						},
						"maxEntries": {
							"type": "number",
							"default": 100,
							"minimum": 10,
							"description": "Maximum cache entries"
						}
					},
					"additionalProperties": false
				},
				"circuitBreaker": {
					"type": "object",
					"description": "Circuit breaker for failing integrations",
					"properties": {
						"failureThreshold": {
							"type": "number",
							"default": 3,
							"minimum": 1,
							"description": "Failures before circuit opens"
						},
						"recoveryTimeMs": {
							"type": "number",
							"default": 60000,
							"description": "Recovery time after circuit opens (1 minute)"
						}
					},
					"additionalProperties": false
				}
			},
			"additionalProperties": false
		}
	},
	"additionalProperties": false
}
