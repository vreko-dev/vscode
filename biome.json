{
	"root": false,
	"extends": ["../biome.json"],
	"formatter": {
		"enabled": true,
		"useEditorconfig": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/out",
			"!**/*.vsix",
			"!**/*.tsbuildinfo"
		]
	}
}
