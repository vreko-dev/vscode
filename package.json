{
  "name": "vreko-vscode",
  "description": "AI code intelligence that learns YOUR patterns. Vreko detects changes, prevents repeated mistakes, and surfaces warnings before the next AI-introduced regression.",
  "version": "3.1.2",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vreko.*",
    "onCommand:vreko.*",
    "workspaceContains:.vrekorc",
    "workspaceContains:.vrekorc"
  ],
  "bugs": "https://github.com/vreko-dev/vscode/issues",
  "qna": "https://github.com/vreko-dev/vscode/discussions",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Vreko requires workspace trust to create snapshots and analyze files. In untrusted workspaces, Vreko will only provide read-only snapshot viewing.",
      "restrictedConfigurations": [
        "vreko.snapshot.autoCreate",
        "vreko.config.enableExecutableConfigs",
        "vreko.guardian.enabled"
      ]
    }
  },
  "categories": [
    "Machine Learning",
    "Testing",
    "Other"
  ],
  "keywords": [
    "ai code intelligence",
    "copilot code learning",
    "claude code memory",
    "windsurf cascade intelligence",
    "ai coding assistant",
    "code snapshots",
    "local-first ai",
    "mcp server",
    "code intelligence",
    "ai detector",
    "codebase learning",
    "github copilot intelligence",
    "codebase memory",
    "behavioral intelligence",
    "workspace intelligence"
  ],
