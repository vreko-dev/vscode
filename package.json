{
  "name": "snapback-vscode",
  "description": "Automatic snapshots for AI-assisted coding. Recover what Cursor, Copilot, or Claude overwrote in <1 second. Your code never leaves your machine.",
  "version": "1.5.4",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:snapback.*",
    "workspaceContains:.snapbackrc"
  ],
  "bugs": "https://github.com/snapback-dev/vscode/issues",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "SnapBack requires workspace trust to create snapshots and analyze files. In untrusted workspaces, SnapBack will only provide read-only snapshot viewing.",
      "restrictedConfigurations": [
        "snapback.snapshot.autoCreate",
        "snapback.config.enableExecutableConfigs",
        "snapback.guardian.enabled"
      ]
    }
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "code protection",
    "cursor",
    "copilot",
    "claude",
    "backup",
    "recovery",
    "snapshots",
    "undo",
    "safety",
    "ai coding",
    "ai assistant",
    "code safety",
    "restore",
    "snapshot",
    "windsurf",
    "local-first",
    "privacy"
  ],
