        "category": "SnapBack",
        "icon": "$(info)"
      },
      {
        "command": "snapback.showAllSnapshots",
        "title": "Show All Snapshots",
        "category": "SnapBack",
        "icon": "$(archive)"
      },
      {
        "command": "snapback.compareWithSnapshot",
        "title": "Compare with Snapshot",
        "category": "SnapBack",
        "icon": "$(diff)"
      },
      {
        "command": "snapback.renameSnapshot",
        "title": "Rename Snapshot",
        "category": "SnapBack",
        "icon": "$(edit)"
      },
      {
        "command": "snapback.protectSnapshot",
        "title": "Protect Snapshot",
        "category": "SnapBack",
        "icon": "$(shield)"
      },
      {
        "command": "snapback.deleteSnapshot",
        "title": "Delete Snapshot",
        "category": "SnapBack",
        "icon": "$(trash)"
      },
      {
        "command": "snapback.restoreSnapshot",
        "title": "Restore Snapshot",
        "category": "SnapBack",
        "icon": "$(debug-step-back)"
      },
      {
        "command": "snapback.snapshot.showFileDiff",
        "title": "Compare with Current",
        "category": "SnapBack",
        "icon": "$(diff)"
      },
      {
        "command": "snapback.deleteOlderSnapshots",
        "title": "Delete Older Snapshots",
        "category": "SnapBack",
        "icon": "$(clear-all)"
      },
      {
        "command": "snapback.unprotectAndDeleteSnapshot",
        "title": "Unprotect and Delete Snapshot",
        "category": "SnapBack",
        "icon": "$(trash)"
      },
      {
        "command": "snapback.openSnapshotInWeb",
        "title": "Open Snapshot in Web",
        "category": "SnapBack",
        "icon": "$(link-external)"
      },
      {
        "command": "snapback.showStatus",
        "title": "Show Protection Status",
        "category": "SnapBack",
        "icon": "$(dashboard)"
      },
      {
        "command": "snapback.refreshViews",
        "title": "Refresh Views",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.refreshTree",
        "title": "Refresh Explorer",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.openProtectedFile",
        "title": "Open Protected File",
        "category": "SnapBack",
        "icon": "$(go-to-file)"
      },
      {
        "command": "snapback.signIn",
        "title": "Sign In",
        "category": "SnapBack",
        "icon": "$(sign-in)"
      },
      {
        "command": "snapback.signOut",
        "title": "Sign Out",
        "category": "SnapBack",
        "icon": "$(sign-out)"
      },
      {
        "command": "snapback.showAuthStatus",
        "title": "Show Authentication Status",
        "category": "SnapBack",
        "icon": "$(account)"
      },
      {
        "command": "snapback.connect",
        "title": "Connect Account",
        "category": "SnapBack",
        "icon": "$(account)"
      },
      {
        "command": "snapback.initialize",
        "title": "Initialize",
        "category": "SnapBack",
        "icon": "$(rocket)"
      },
      {
        "command": "snapback.openWalkthrough",
        "title": "Show Welcome Guide",
        "category": "SnapBack",
        "icon": "$(question)"
      },
      {
        "command": "snapback.showWelcomePanel",
        "title": "Show Welcome Panel (Fallback)",
        "category": "SnapBack",
        "icon": "$(info)"
      },
      {
        "command": "snapback.resetWelcomeState",
        "title": "Reset Welcome State (Debug)",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.openDocumentation",
        "title": "Open Documentation",
        "category": "SnapBack",
        "icon": "$(book)"
      },
      {
        "command": "snapback.updateConfiguration",
        "title": "Update Configuration",
        "category": "SnapBack",
        "icon": "$(gear)"
      },
      {
        "command": "snapback.toggleOfflineMode",
        "title": "Toggle Offline Mode",
        "category": "SnapBack",
        "icon": "$(globe)"
      },
      {
        "command": "snapback.resetNotificationPreferences",
        "title": "Reset Notification Preferences",
        "category": "SnapBack",
        "icon": "$(bell-slash)"
      },
      {
        "command": "snapback.showFileHealthStatus",
        "title": "Show File Health Status",
        "category": "SnapBack",
        "icon": "$(pulse)"
      },
      {
        "command": "snapback.refreshFileHealthDecorations",
        "title": "Refresh File Health Decorations",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.clearFileHealthDecorations",
        "title": "Clear File Health Decorations",
        "category": "SnapBack",
        "icon": "$(clear-all)"
      },
      {
        "command": "snapback.getAuthState",
        "title": "Test: Get Auth State",
        "category": "SnapBack Test"
      },
      {
        "command": "snapback.test.getSnapshots",
        "title": "Test: Get Snapshots",
        "category": "SnapBack Test"
      },
      {
        "command": "snapback.test.restoreSnapshot",
        "title": "Test: Restore Snapshot",
        "category": "SnapBack Test"
      },
      {
        "command": "snapback.migrateSecureConfig",
        "title": "Migrate API Keys to Secure Storage",
        "category": "SnapBack",
        "icon": "$(shield)"
      },
      {
        "command": "snapback.setApiKey",
        "title": "Set API Key (Secure)",
        "category": "SnapBack",
        "icon": "$(key)"
      },
      {
        "command": "snapback.setMcpAuthToken",
        "title": "Set MCP Auth Token (Secure)",
        "category": "SnapBack",
        "icon": "$(key)"
      },
      {
        "command": "snapback.mcp.configure",
        "title": "Configure AI Assistants",
        "category": "SnapBack MCP",
        "icon": "$(extensions)"
      },
      {
        "command": "snapback.mcp.check",
        "title": "Run Code Check",
        "category": "SnapBack MCP",
        "icon": "$(check)"
      },
      {
        "command": "snapback.mcp.checkPatterns",
        "title": "Check Code Patterns",
        "category": "SnapBack MCP",
        "icon": "$(search)"
      },
      {
        "command": "snapback.mcp.startTask",
        "title": "Start Development Task",
        "category": "SnapBack MCP",
        "icon": "$(play)"
      },
      {
        "command": "snapback.mcp.endTask",
        "title": "End Development Task",
        "category": "SnapBack MCP",
        "icon": "$(debug-stop)"
      },
      {
        "command": "snapback.mcp.status",
        "title": "Show AI Assistant Status",
        "category": "SnapBack MCP",
        "icon": "$(info)"
      },
      {
        "command": "snapback.mcp.reset",
        "title": "Reset MCP Configuration State",
        "category": "SnapBack MCP",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.mcp.disable",
        "title": "Disable SnapBack for AI Assistant",
        "category": "SnapBack MCP",
        "icon": "$(close)"
      },
      {
        "command": "snapback.openVitalsDashboard",
        "title": "Open Vitals Dashboard",
        "category": "SnapBack",
        "icon": "$(dashboard)"
      },
      {
        "command": "snapback.openDashboard",
        "title": "Open Dashboard",
        "category": "SnapBack",
        "icon": "$(home)"
      },
      {
        "command": "snapback.toggleVitalsDisplay",
        "title": "Toggle Vitals in Status Bar",
        "category": "SnapBack",
        "icon": "$(pulse)"
      },
      {
        "command": "snapback.refreshVitals",
        "title": "Refresh Vitals Data",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.showQuickPicker",
        "title": "Show Snapshot Picker",
        "category": "SnapBack",
        "icon": "$(history)"
      },
      {
        "command": "snapback.quickRestore",
        "title": "Quick Restore",
        "category": "SnapBack",
        "icon": "$(debug-step-back)"
      },
      {
        "command": "snapback.ai.injectRules",
        "title": "Inject AI Agent Rules",
        "category": "SnapBack",
        "icon": "$(extensions)"
      },
      {
        "command": "snapback.ai.resetRulesConfig",
        "title": "Reset Agent Rules Config",
        "category": "SnapBack",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "snapback",
          "title": "SnapBack",
          "icon": "media/activitybar-icon-24.png"
        }
      ]
    },
    "views": {
      "snapback": [
        {
          "id": "snapback.dashboard",
          "name": "SnapBack",
          "when": "snapback.isActive && config.snapback.ui.showTreeView",
          "icon": "$(shield)"
        },
        {
          "id": "snapback.protectedFiles",
          "name": "Protected Files",
          "when": "snapback.isActive && config.snapback.ui.showTreeView",
          "icon": "$(lock)"
        },
        {
          "id": "snapback.sessions",
          "name": "Sessions",
          "when": "snapback.isActive && config.snapback.ui.showTreeView"
        }
      ]
    },
    "submenus": [
      {
        "id": "snapback.protectFile",
        "label": "SnapBack: Protect File"
      },
      {
        "id": "snapback.changeProtectionLevel",
        "label": "SnapBack: Change Protection Level"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "snapback.createSnapshot",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@1"
        },
        {
          "command": "snapback.snapBack",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@2"
        },
        {
          "submenu": "snapback.protectFile",
          "when": "snapback.isActive && !explorerResourceIsFolder && !snapback.isProtected",
          "group": "snapback@3"
        },
        {
          "submenu": "snapback.changeProtectionLevel",
          "when": "snapback.isActive && !explorerResourceIsFolder && snapback.isProtected",
          "group": "snapback@3"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "snapback.isActive && !explorerResourceIsFolder && snapback.isProtected",
          "group": "snapback@3"
        },
        {
          "command": "snapback.compareWithSnapshot",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@4"
        },
        {
          "command": "snapback.createPolicyOverride",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@5"
        }
      ],
      "snapback.protectFile": [
        {
          "command": "snapback.setWatchLevel",
          "group": "levels@1",
          "when": "snapback.canProtect"
        },
        {
          "command": "snapback.setWarnLevel",
          "group": "levels@2",
          "when": "snapback.canProtect"
        },
        {
          "command": "snapback.setBlockLevel",
          "group": "levels@3",
          "when": "snapback.canProtect"
        }
      ],
      "snapback.changeProtectionLevel": [
        {
          "command": "snapback.setWatchLevel",
          "group": "levels@1",
          "when": "snapback.isProtected && snapback.currentLevel != 'watch'"
        },
        {
          "command": "snapback.setWarnLevel",
          "group": "levels@2",
          "when": "snapback.isProtected && snapback.currentLevel != 'warn'"
        },
        {
          "command": "snapback.setBlockLevel",
          "group": "levels@3",
          "when": "snapback.isProtected && snapback.currentLevel != 'block'"
        }
      ],
      "editor/context": [
        {
          "submenu": "snapback.protectFile",
          "when": "snapback.isActive && !snapback.isProtected",
          "group": "snapback@1"
        },
        {
          "submenu": "snapback.changeProtectionLevel",
          "when": "snapback.isActive && snapback.isProtected",
          "group": "snapback@1"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "snapback.isActive && snapback.isProtected",
          "group": "snapback@2"
        },
        {
          "command": "snapback.createSnapshot",
          "when": "snapback.isActive",
          "group": "snapback@3"
        },
        {
          "command": "snapback.createPolicyOverride",
          "when": "snapback.isActive",
          "group": "snapback@4"
        },
        {
          "command": "snapback.toggleOfflineMode",
          "when": "snapback.isActive",
          "group": "snapback@5"
        }
      ],
      "commandPalette": [
        {
          "command": "snapback.protectFile",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.protectCurrentFile",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.changeProtectionLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.setWatchLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.setWarnLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.setBlockLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "snapback.isActive && snapback.fileProtected"
        },
        {
          "command": "snapback.compareWithSnapshot",
          "when": "snapback.isActive"
        },
        {
          "command": "snapback.openProtectedFile",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "snapback.openProtectedFile",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "navigation@1"
        },
        {
          "submenu": "snapback.changeProtectionLevel",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "protection@1"
        },
        {
          "command": "snapback.createSnapshot",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "snapshot@1",
          "icon": "$(save)"
        },
        {
          "command": "snapback.snapBack",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "snapshot@2",
          "icon": "$(history)"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "danger@1",
          "icon": "$(unlock)"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "view == snapback.main && viewItem == snapback.item.protectedFile",
          "group": "danger@1",
          "icon": "$(unlock)"
        },
        {
          "command": "snapback.openSnapshotInWeb",
          "when": "view == snapbackExplorer && viewItem == snapshot",
          "group": "navigation@1",
          "icon": "$(link-external)"
        },
        {
          "command": "snapback.createSnapshot",
          "when": "view == snapbackExplorer && viewItem == blockingIssue",
          "group": "snapshot@1",
          "icon": "$(save)"
        },
        {
          "command": "snapback.snapshot.showFileDiff",
          "when": "view == snapback.dashboard && viewItem == activityEventSingle",
          "group": "inline"
        },
        {
          "command": "snapback.snapshot.showFileDiff",
          "when": "view == snapback.dashboard && viewItem == activityFile",
          "group": "inline"
        },
        {
          "command": "snapback.restoreSnapshot",
          "when": "view == snapback.dashboard && viewItem =~ /^activityEvent/",
          "group": "inline@1"
        },
        {
          "command": "snapback.deleteSnapshot",
          "when": "view == snapback.dashboard && viewItem =~ /^activityEvent/",
          "group": "inline@2"
        },
        {
          "command": "snapback.restoreSnapshot",
          "when": "view == snapback.dashboard && viewItem =~ /^activityEvent/",
          "group": "snapshot@1"
        },
        {
          "command": "snapback.deleteSnapshot",
          "when": "view == snapback.dashboard && viewItem =~ /^activityEvent/",
          "group": "danger@1"
        }
      ],
      "view/title": [
        {
          "command": "snapback.session.restore",
          "when": "view == snapback.dashboard",
          "group": "navigation@1",
          "icon": "$(debug-step-back)"
        },
        {
          "command": "snapback.createSnapshot",
          "when": "view == snapback.dashboard",
          "group": "navigation@2",
          "icon": "$(save)"
        },
        {
          "command": "snapback.showAllSnapshots",
          "when": "view == snapback.dashboard",
          "group": "navigation@3",
          "icon": "$(archive)"
        },
        {
          "command": "snapback.refreshViews",
          "when": "view == snapback.dashboard",
          "group": "navigation@4",
          "icon": "$(refresh)"
        },
        {
          "command": "snapback.showStatus",
          "when": "view == snapback.dashboard && snapback.protectionStatus == complete",
          "group": "navigation@5",
          "icon": "$(shield-check)"
        },
        {
          "command": "snapback.protectEntireRepo",
          "when": "view == snapback.dashboard && snapback.protectionStatus != complete",
          "group": "navigation@6"
        },
        {
          "command": "snapback.refreshViews",
          "when": "view == snapback.protectedFiles",
          "group": "navigation@1",
          "icon": "$(refresh)"
        },
        {
          "command": "snapback.showAllProtectedFiles",
          "when": "view == snapback.protectedFiles",
          "group": "navigation@2",
          "icon": "$(list-tree)"
        }
      ]
    },
    "configuration": {
      "title": "SnapBack",
      "properties": {
        "snapback.aiDetection.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Enable AI Detection**\n\nDetects AI-generated code changes and creates automatic protection snapshots.",
          "order": 1
        },
        "snapback.showAutoSnapshotNotifications": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Show Snapshot Notifications**\n\nDisplay brief notifications when auto-snapshots are created.",
          "order": 2
        },
        "snapback.guardian.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Enable Guardian**\n\nProtects against risky code patterns: secrets, mock replacements, phantom dependencies.",
          "order": 3
        },
        "snapback.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Enable MCP Integration**\n\nAllows AI assistants (Claude, Cursor, Windsurf) to interact with SnapBack.",
          "order": 4
        },
        "snapback.mcp.serverUrl": {
          "type": "string",
          "default": "https://mcp.snapback.dev",
          "markdownDescription": "**MCP Server URL**\n\nURL for the remote MCP server. Leave default for cloud, or set to local server.",
          "order": 5
        },
        "snapback.offlineMode.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Offline Mode**\n\nDisable all network requests. Snapshots work locally only.",
          "order": 6
        },
        "snapback.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "info",
          "markdownDescription": "**Log Level**\n\nFor troubleshooting. Set to `debug` for verbose output.",
          "order": 7
        },
        "snapback.ui.showTreeView": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Show Sidebar Tree View**\n\nEnable the full SnapBack tree view in the Activity Bar. When off, uses minimal status bar UI.",
          "order": 8
        }
      }
    },
    "keybindings": [
      {
        "command": "snapback.protectFile",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorFocus"
      },
      {
        "command": "snapback.createSnapshot",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorFocus"
      },
      {
        "command": "snapback.snapBack",
        "key": "ctrl+alt+z",
        "mac": "cmd+alt+z"
      },
      {
        "command": "snapback.deleteSnapshot",
        "key": "delete",
        "when": "focusedView == snapback.main && viewItem == snapshot"
      },
      {
        "command": "snapback.renameSnapshot",
        "key": "f2",
        "when": "focusedView == snapback.main && viewItem == snapshot"
      },
      {
        "command": "snapback.quickRestore",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "walkthroughs": [
      {
        "id": "snapback.welcome",
        "title": "Get Started with SnapBack",
        "description": "Learn the three protection levels and protect your first file in 2 minutes",
        "steps": [
          {
            "id": "snapback.understand-levels",
            "title": "Three Levels of Protection",
            "description": "SnapBack gives you precise control with three protection levels:\n\n**🟢 Watch** - Silent auto-snapshotting (no interruptions)\n\n**🟡 Warn** - Confirm before saving (safety prompt)\n\n**🔴 Block** - Required snapshot note (maximum protection)\n\nChoose the right level for each file based on how critical it is.",
            "media": {
              "markdown": "## When to Use Each Level\n\n### 🟢 Watch - Most Files\n- Configs you edit often\n- Code you're actively working on\n- Files where you want automatic safety\n\n### 🟡 Warn - Important Files\n- Files that affect multiple systems\n- Database migrations\n- Build configurations\n\n### 🔴 Block - Critical Files\n- `package.json`, `.env` files\n- Authentication code\n- Payment processing\n- Anything that could break production"
            }
          },
          {
            "id": "snapback.protect-first-file",
            "title": "Protect Your First File",
            "description": "Let's protect a file together:\n\n1. Right-click any file in the Explorer\n2. Hover over **SnapBack: Set Protection Level**\n3. Choose **🧢 Watch Level** (silent mode)\n4. The file now gets automatic snapshots when you save\n\n[Open a file to try it now](command:workbench.action.quickOpen)",
            "media": {
              "markdown": "## Protection Levels Menu\n\nWhen you right-click a file, you'll see:\n\n``````\n\n**Pro Tip:** You can also use the Command Palette:\n- Press `Ctrl+Shift+P` (or `Cmd+Shift+P` on Mac)\n- Type \"SnapBack: Protect File\"\n- Choose your protection level"
            },
            "completionEvents": [
              "onCommand:snapback.protectFile",
              "onCommand:snapback.setWatchLevel"
            ]
          },
          {
            "id": "snapback.see-it-work",
            "title": "See Protection in Action",
            "description": "Now make a change to your protected file and save it.\n\n✅ **Watch level** creates a snapshot silently\n✅ Status bar shows confirmation briefly\n✅ No interruptions to your flow\n\nNotice how the file badge in the Explorer shows it's protected.",
            "media": {
              "markdown": "## What Happens When You Save?\n\n### 🟢 Watch Level\n- Snapshot created automatically\n- Brief status bar message\n- No interruption\n\n### 🟡 Warn Level\n- Confirmation dialog appears\n- You can add a note (optional)\n- Click \"Save\" to continue\n\n### 🔴 Block Level\n- Dialog requires a note\n- Note helps you remember why you made the change\n- Cannot save without adding context"
            }
          },
          {
            "id": "snapback.explore-snapshots",
            "title": "Snap Back (Restore Snapshots)",
            "description": "Open the SnapBack sidebar to see all your snapshots:\n\n1. Click the SnapBack icon in the Activity Bar (left sidebar)\n2. Browse your snapshot history\n3. Click any snapshot to view details\n4. Use \"Snap Back\" to restore\n\n[Open SnapBack View](command:workbench.view.extension.snapback)",
            "media": {
              "code": "## Viewing Your Snapshots\n\n### SnapBack Sidebar\nClick the SnapBack icon (🧢) in the Activity Bar to see:\n- All your snapshots in chronological order\n- File-specific snapshot history\n- Protected files list\n- Quick restore and compare actions\n\n### Protected Files View\nIn the Explorer sidebar, expand **SNAPBACK PROTECTED FILES** to:\n- See all protected files at a glance\n- View protection levels (🟢 Watch, 🟡 Warn, 🔴 Block)\n- Right-click for quick actions\n\n### Keyboard Shortcuts\n- `Ctrl+Alt+S` / `Cmd+Alt+S` - Create Snapshot\n- `Ctrl+Alt+Z` / `Cmd+Alt+Z` - Snap Back (Restore)\n- `Ctrl+Alt+P` / `Cmd+Alt+P` - Protect Current File\n\n💡 **Pro Tip:** Right-click any protected file for quick snapshot actions!"
            },
            "completionEvents": [
              "onView:snapback.main"
            ]
          },
          {
            "id": "snapback.team-protection",
            "title": "Bonus: Team Protection Policies",
            "description": "Share protection policies with your team using `.snapbackrc` configuration:\n\n1. Create `.snapbackrc` in your repo root\n2. Add patterns with protection levels\n3. Commit to Git\n\n**Everyone on your team gets the same protection automatically.**",
            "media": {
              "code": "## Team Configuration Example\n\nCreate `.snapbackrc` in your project root:\n\n``````\n\n**Benefits:**\n- Consistent protection across the team\n- New team members get protection automatically\n- Reduce accidental breaking changes"
            }
          }
        ]
      }
    ],
    "viewsWelcome": [
      {
        "view": "snapback.protectedFiles",
        "contents": "No protected files yet.\n\nProtect your first file to see it here.\n\n[🧢 Protect File](command:snapback.protectFile)\n\nLearn about [protection levels](command:snapback.openWalkthrough).",
        "when": "!snapback.hasProtectedFiles"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": ".snapbackrc",
        "url": "./schemas/snapbackrc.schema.json"
      }
    ]
  },
