    "submenus": [
      {
        "id": "vreko.protectFile",
        "label": "Vreko: Protect File"
      },
      {
        "id": "vreko.changeProtectionLevel",
        "label": "Vreko: Change Protection Level"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "vreko.protectFile",
          "when": "vreko.isActive && !explorerResourceIsFolder && !vreko.isProtected",
          "group": "vreko@3"
        },
        {
          "submenu": "vreko.changeProtectionLevel",
          "when": "vreko.isActive && !explorerResourceIsFolder && vreko.isProtected",
          "group": "vreko@3"
        },
        {
          "command": "vreko.unprotectFile",
          "when": "vreko.isActive && !explorerResourceIsFolder && vreko.isProtected",
          "group": "vreko@3"
        },
        {
          "command": "vreko.compareWithSnapshot",
          "when": "vreko.isActive && !explorerResourceIsFolder",
          "group": "vreko@4"
        }
      ],
      "vreko.protectFile": [
        {
          "command": "vreko.setWatchLevel",
          "group": "levels@1",
          "when": "vreko.canProtect"
        },
        {
          "command": "vreko.setWarnLevel",
          "group": "levels@2",
          "when": "vreko.canProtect"
        },
        {
          "command": "vreko.setBlockLevel",
          "group": "levels@3",
          "when": "vreko.canProtect"
        }
      ],
      "vreko.changeProtectionLevel": [
        {
          "command": "vreko.setWatchLevel",
          "group": "levels@1",
          "when": "vreko.isProtected && vreko.currentLevel != 'watch'"
        },
        {
          "command": "vreko.setWarnLevel",
          "group": "levels@2",
          "when": "vreko.isProtected && vreko.currentLevel != 'warn'"
        },
        {
          "command": "vreko.setBlockLevel",
          "group": "levels@3",
          "when": "vreko.isProtected && vreko.currentLevel != 'block'"
        }
      ],
      "editor/context": [
        {
          "submenu": "vreko.protectFile",
          "when": "vreko.isActive && !vreko.isProtected",
          "group": "vreko@1"
        },
        {
          "submenu": "vreko.changeProtectionLevel",
          "when": "vreko.isActive && vreko.isProtected",
          "group": "vreko@1"
        },
        {
          "command": "vreko.unprotectFile",
          "when": "vreko.isActive && vreko.isProtected",
          "group": "vreko@2"
        },
        {
          "command": "vreko.toggleOfflineMode",
          "when": "vreko.isActive",
          "group": "vreko@5"
        }
      ],
      "view/item/context": [
        {
          "command": "vreko.compareWithSnapshot",
          "when": "viewItem =~ /^vreko\\.activityEvent/",
          "group": "1_restore@2"
        },
        {
          "command": "vreko.deleteSnapshot",
          "when": "viewItem =~ /^vreko\\.activityEvent/",
          "group": "9_danger@1"
        },
        {
          "command": "vreko.openProtectedFile",
          "when": "viewItem =~ /^vreko\\.protectedFile/",
          "group": "navigation@1"
        },
        {
          "submenu": "vreko.changeProtectionLevel",
          "when": "viewItem =~ /^vreko\\.protectedFile/",
          "group": "1_protection@1"
        },
        {
          "command": "vreko.unprotectFile",
          "when": "viewItem =~ /^vreko\\.protectedFile/",
          "group": "9_danger@1"
        },
        {
          "command": "vreko.session.restore",
          "when": "viewItem == vreko.session.restorable",
          "group": "inline@1"
        },
        {
          "command": "vreko.session.restore",
          "when": "viewItem == vreko.session.restorable",
          "group": "1_restore@1"
        },
        {
          "command": "vreko.compareWithSnapshot",
          "when": "viewItem =~ /^vreko\\.session/",
          "group": "1_restore@2"
        }
      ],
      "view/title": [
        {
          "command": "vreko.session.restore",
          "group": "navigation@1",
          "icon": "$(debug-step-back)"
        },
        {
          "command": "vreko.showFullHistory",
          "group": "navigation@3",
          "icon": "$(archive)"
        },
        {
          "command": "vreko.openCeremony",
          "group": "navigation@5",
          "icon": "$(history)"
        },
        {
          "command": "vreko.protectEntireRepo",
          "when": "vreko.protectionStatus != complete",
          "group": "navigation@6"
        },
        {
          "command": "vreko.showAllProtectedFiles",
          "group": "navigation@2",
          "icon": "$(list-tree)"
        }
      ]
    },
    "configuration": {
      "title": "Vreko",
      "properties": {
        "vreko.showAutoSnapshotNotifications": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Show Snapshot Notifications**\n\nDisplay brief notifications when auto-snapshots are created.",
          "order": 2
        },
        "vreko.guardian.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Enable Guardian**\n\nProtects against risky code patterns: secrets, mock replacements, phantom dependencies.",
          "order": 3
        },
        "vreko.mcp.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Enable MCP Integration**\n\nAllows AI assistants (Claude, Cursor, Windsurf) to interact with Vreko.",
          "order": 4
        },
        "vreko.mcp.serverUrl": {
          "type": "string",
          "default": "https://mcp.vreko.dev",
          "markdownDescription": "**MCP Server URL**\n\nURL for the remote MCP server. Leave default for cloud, or set to local server.",
          "order": 5
        },
        "vreko.offlineMode.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "**Offline Mode**\n\nDisable all network requests. Snapshots work locally only.",
          "order": 6
        },
        "vreko.logLevel": {
          "type": "string",
          "enum": [
            "silent",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "default": "info",
          "markdownDescription": "**Log Level**\n\nFor troubleshooting. Set to `debug` for verbose output, `trace` for maximum detail, or `silent` to disable all logging.",
          "order": 7
        },
        "vreko.ui.hideInternalFiles": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Hide Internal Files**\n\nHide `.vreko/` directory contents in VS Code explorer. Internal files are implementation details users don't need to see.",
          "order": 9
        },
        "vreko.ui.statusBarEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Vreko status in the status bar"
        },
        "vreko.ui.fileDecorationsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show fragile and agent-touched badges in file explorer"
        },
        "vreko.ui.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens on fragile and agent-touched files"
        },
        "vreko.ui.notificationLevel": {
          "type": "string",
          "enum": [
            "normal",
            "quiet",
            "silent"
          ],
          "default": "normal",
          "description": "Control Vreko notification verbosity"
        },
        "vreko.ui.outputChannelVerbose": {
          "type": "boolean",
          "default": false,
          "description": "Log all daemon events to Vreko Activity output channel"
        },
        "vreko.ui.liveWebviewAutoOpen": {
          "type": "boolean",
          "default": false,
          "description": "Auto-open Vreko Live panel on session start"
        },
        "vreko.mcp.autoEnable": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Auto-Configure MCP**\n\nAutomatically configure MCP for detected AI assistants (Cursor, Claude Desktop, Windsurf) on extension activation.",
          "order": 10
        },
        "vreko.mcp.healthGuardian.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Enable Health Guardian**\n\nEnable proactive health monitoring for MCP server.",
          "order": 11
        },
        "vreko.mcp.healthGuardian.activePollingInterval": {
          "type": "number",
          "default": 3000,
          "minimum": 1000,
          "maximum": 10000,
          "markdownDescription": "**Active Polling Interval (ms)**\n\nPolling interval when AI tools are actively being used.",
          "order": 12
        },
        "vreko.mcp.healthGuardian.idlePollingInterval": {
          "type": "number",
          "default": 10000,
          "minimum": 5000,
          "maximum": 60000,
          "markdownDescription": "**Idle Polling Interval (ms)**\n\nPolling interval when VS Code is focused but no AI activity.",
          "order": 13
        },
        "vreko.mcp.healthGuardian.degradedLatencyThreshold": {
          "type": "number",
          "default": 500,
          "minimum": 100,
          "maximum": 5000,
          "markdownDescription": "**Degraded Latency Threshold (ms)**\n\nLatency threshold above which MCP is considered degraded.",
          "order": 14
        },
        "vreko.mcp.healthGuardian.unhealthyLatencyThreshold": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 10000,
          "markdownDescription": "**Unhealthy Latency Threshold (ms)**\n\nLatency threshold above which MCP is considered unhealthy.",
          "order": 15
        },
        "vreko.mcp.healthGuardian.proactiveAlerts": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "**Proactive Alerts**\n\nShow toast notifications when MCP health changes.",
          "order": 16
        },
        "vreko.mcp.healthGuardian.deepCheckFrequency": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 20,
          "markdownDescription": "**Deep Check Frequency**\n\nPerform deep health check every N shallow checks.",
          "order": 17
        }
      }
    },
    "configurationDefaults": {
      "files.exclude": {
        "**/.vreko": true
      }
    },
    "keybindings": [
      {
        "command": "vreko.protectFile",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorFocus"
      },
      {
        "command": "vreko.quickRestore",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      },
      {
        "command": "vreko.compareWithSnapshot",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorFocus"
      }
    ],
    "walkthroughs": [
      {
        "id": "vreko.welcome",
        "title": "Get Started with Vreko",
        "description": "Intelligence that compounds. Day 1 → Day 30 → Day 90.",
        "steps": [
          {
            "id": "vreko.intelligence-active",
            "title": "Your Codebase, Understood",
            "description": "Vreko's intelligence is already active.\n\n✅ **Automatic snapshots** on every save\n✅ **AI detection** for Cursor, Copilot, Claude, Windsurf\n✅ **Behavioral Intelligence** learning your codebase\n✅ **Local-first** - your code never leaves your machine\n\nNo configuration needed. Your codebase intelligence starts now.",
            "media": {
              "markdown": "media/walkthrough/intelligence-active.md"
            }
          },
          {
            "id": "vreko.see-ai-touches",
            "title": "See What AI Touches",
            "description": "When AI tools modify your code, Vreko shows you.\n\n**AI Provenance Markers**\n- Gutter icons show AI-modified lines\n- Different icons for Cursor, Copilot, Claude, Windsurf\n- Inline annotations explain what changed\n\n**Try It**\n1. Use an AI tool to make a change\n2. Look for the ⚙️ icon in the gutter\n3. Hover to see which AI tool made the change\n\n[Create a Snapshot](command:vreko.createSnapshot)",
            "media": {
              "markdown": "media/walkthrough/see-ai-touches.md"
            },
            "completionEvents": [
              "onCommand:vreko.createSnapshot"
            ]
          },
          {
            "id": "vreko.pattern-memory",
            "title": "Behavioral Intelligence",
            "description": "Vreko learns YOUR codebase.\n\n**The Intelligence Journey**\n- **Day 1-7**: Detection  -  \"3 AI modifications detected\"\n- **Day 8-30**: Patterns  -  \"Auth files often change together\"\n- **Day 30+**: Predictions  -  \"Elevated risk detected\"\n\n**What Gets Learned**\n- Fragile files that break often\n- Co-change patterns (files that change together)\n- Risk patterns that lead to bugs\n\n[Open Timeline](command:vreko.showQuickPicker)",
            "media": {
              "markdown": "media/walkthrough/pattern-memory.md"
            },
            "completionEvents": [
              "onCommand:vreko.showQuickPicker"
            ]
          },
          {
            "id": "vreko.closing-ceremony",
            "title": "Your First Closing Ceremony",
            "description": "When you end a session, Vreko shows a summary.\n\n**What You'll See**\n- 📊 Snapshots created this session\n- 📁 Files modified\n- 🤖 AI tools detected\n- 🧠 Learnings captured\n- 📈 Session coherence score\n\n**The Compounding Value**\nEach session adds to your codebase intelligence.\nPatterns emerge. Predictions improve.\n\n[Open Closing Ceremonies](command:vreko.openCeremony)",
            "media": {
              "markdown": "media/walkthrough/closing-ceremony.md"
            },
            "completionEvents": []
          },
          {
            "id": "vreko.connect-ai-tools",
            "title": "Connect Your AI Tools (Optional)",
            "description": "Get deeper AI integration with MCP.\n\n**Model Context Protocol (MCP)**\n- Connect Cursor or Claude directly to Vreko\n- AI can query your codebase history\n- Smarter AI suggestions with context\n\n**Setup**\n1. Open your AI tool's MCP settings\n2. Add Vreko's MCP server\n3. AI gets instant access to your patterns\n\n[View MCP Documentation](https://vreko.dev/docs/mcp)",
            "media": {
              "markdown": "media/walkthrough/connect-ai-tools.md"
            },
            "when": "config.vreko.showMcpStep"
          }
        ]
      }
    ],
