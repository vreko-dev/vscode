{
  "name": "snapback-vscode",
  "description": "Smart snapshot manager with Watch/Warn/Block protection levels. Code Breaks. SnapBack.",
  "version": "1.4.1",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:snapback.*",
    "workspaceContains:.snapbackrc"
  ],
  "bugs": "https://github.com/snapback-dev/vscode/issues",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "SnapBack requires workspace trust to create snapshots and analyze files. In untrusted workspaces, SnapBack will only provide read-only snapshot viewing.",
      "restrictedConfigurations": [
        "snapback.snapshot.autoCreate",
        "snapback.config.enableExecutableConfigs",
        "snapback.guardian.enabled"
      ]
    }
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "snapshot",
    "backup",
    "code-safety",
    "ai-protection",
    "copilot",
    "cursor",
    "windsurf",
    "recovery",
    "rollback",
    "file-protection",
    "git",
    "version-control",
    "developer-tools",
    "typescript",
    "javascript",
    "productivity",
    "security",
    "code-quality",
    "automation",
    "testing",
    "ci-cd",
    "open-source",
    "sdk",
    "local-first",
    "ai-safety"
  ],
  "contributes": {
    "authentication": [
      {
        "id": "snapback",
        "label": "SnapBack"
      }
    ],
    "commands": [
      {
        "comment": "═══════════════════════════════════════════════════════════════════════════════",
        "comment2": "Protection Commands - File-level protection management",
        "comment3": "═══════════════════════════════════════════════════════════════════════════════"
      },
      {
        "command": "snapback.protectFile",
        "title": "Protect File",
        "category": "SnapBack",
        "icon": "$(shield)"
      },
      {
        "command": "snapback.protectCurrentFile",
        "title": "Protect Current File",
        "category": "SnapBack",
        "icon": "$(shield)"
      },
      {
        "command": "snapback.protectEntireRepo",
        "title": "Apply Protection Defaults",
        "category": "SnapBack",
        "icon": "$(shield)"
      },
      {
        "command": "snapback.unprotectFile",
        "title": "Unprotect File",
        "category": "SnapBack",
        "icon": "$(unlock)"
      },
      {
        "command": "snapback.changeProtectionLevel",
        "title": "Change Protection Level",
        "category": "SnapBack",
        "icon": "$(settings-gear)"
      },
      {
        "command": "snapback.setWatchLevel",
        "title": "Set Protection: Watch (Silent)",
        "category": "SnapBack",
        "icon": "$(eye)"
      },
      {
        "command": "snapback.setWarnLevel",
        "title": "Set Protection: Warn (Notify)",
        "category": "SnapBack",
        "icon": "$(warning)"
      },
      {
        "command": "snapback.setBlockLevel",
        "title": "Set Protection: Block (Required)",
        "category": "SnapBack",
        "icon": "$(error)"
      },
      {
        "command": "snapback.showAllProtectedFiles",
        "title": "Show All Protected Files",
        "category": "SnapBack",
        "icon": "$(list-tree)"
      },
      {
        "command": "snapback.createPolicyOverride",
        "title": "Create Policy Override",
        "category": "SnapBack",
        "icon": "$(symbol-event)"
      },
      {
        "comment": "═══════════════════════════════════════════════════════════════════════════════",
        "comment2": "Snapshot Commands - Snapshot creation and restoration",
        "comment3": "═══════════════════════════════════════════════════════════════════════════════"
      },
      {
        "command": "snapback.createSnapshot",
        "title": "Create Snapshot",
        "category": "SnapBack",
        "icon": "$(save)"
      },
      {
        "command": "snapback.snapBack",
        "title": "Snap Back (Restore)",
        "category": "SnapBack",
        "icon": "$(history)"
      },
      {
        "command": "snapback.restoreLastSnapshot",
        "title": "Restore Last Snapshot",
        "category": "SnapBack",
        "icon": "$(history)"
      },
      {
        "command": "snapback.viewSnapshot",
        "title": "View Snapshot Details",
        "category": "SnapBack",
        "icon": "$(info)"
      },
      {
        "command": "snapback.showAllSnapshots",
        "title": "Show All Snapshots",
        "category": "SnapBack",
        "icon": "$(archive)"
      },
      {
        "command": "snapback.compareWithSnapshot",
        "title": "Compare with Snapshot",
        "category": "SnapBack",
        "icon": "$(diff)"
      },
      {
        "command": "snapback.renameSnapshot",
        "title": "Rename Snapshot",
        "category": "SnapBack",
        "icon": "$(edit)"
      },
      {
        "command": "snapback.protectSnapshot",
        "title": "Protect Snapshot",
        "category": "SnapBack",
        "icon": "$(shield)"
      },
      {
        "command": "snapback.deleteSnapshot",
        "title": "Delete Snapshot",
        "category": "SnapBack",
        "icon": "$(trash)"
      },
      {
        "command": "snapback.deleteOlderSnapshots",
        "title": "Delete Older Snapshots",
        "category": "SnapBack",
        "icon": "$(clear-all)"
      },
      {
        "command": "snapback.unprotectAndDeleteSnapshot",
        "title": "Unprotect and Delete Snapshot",
        "category": "SnapBack",
        "icon": "$(trash)"
      },
      {
        "command": "snapback.openSnapshotInWeb",
        "title": "Open Snapshot in Web",
        "category": "SnapBack",
        "icon": "$(link-external)"
      },
      {
        "comment": "═══════════════════════════════════════════════════════════════════════════════",
        "comment2": "View Commands - UI navigation and refresh",
        "comment3": "═══════════════════════════════════════════════════════════════════════════════"
      },
      {
        "command": "snapback.showStatus",
        "title": "Show Protection Status",
        "category": "SnapBack",
        "icon": "$(dashboard)"
      },
      {
        "command": "snapback.refreshViews",
        "title": "Refresh Views",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.refreshTree",
        "title": "Refresh Explorer",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.openProtectedFile",
        "title": "Open Protected File",
        "category": "SnapBack",
        "icon": "$(go-to-file)"
      },
      {
        "comment": "═══════════════════════════════════════════════════════════════════════════════",
        "comment2": "Account Commands - Authentication and connection",
        "comment3": "═══════════════════════════════════════════════════════════════════════════════"
      },
      {
        "command": "snapback.signIn",
        "title": "Sign In",
        "category": "SnapBack",
        "icon": "$(sign-in)"
      },
      {
        "command": "snapback.signOut",
        "title": "Sign Out",
        "category": "SnapBack",
        "icon": "$(sign-out)"
      },
      {
        "command": "snapback.showAuthStatus",
        "title": "Show Authentication Status",
        "category": "SnapBack",
        "icon": "$(account)"
      },
      {
        "command": "snapback.connect",
        "title": "Connect Account",
        "category": "SnapBack",
        "icon": "$(account)"
      },
      {
        "comment": "═══════════════════════════════════════════════════════════════════════════════",
        "comment2": "Utility Commands - Settings, help, and configuration",
        "comment3": "═══════════════════════════════════════════════════════════════════════════════"
      },
      {
        "command": "snapback.initialize",
        "title": "Initialize",
        "category": "SnapBack",
        "icon": "$(rocket)"
      },
      {
        "command": "snapback.openWalkthrough",
        "title": "Show Welcome Guide",
        "category": "SnapBack",
        "icon": "$(question)"
      },
      {
        "command": "snapback.openDocumentation",
        "title": "Open Documentation",
        "category": "SnapBack",
        "icon": "$(book)"
      },
      {
        "command": "snapback.updateConfiguration",
        "title": "Update Configuration",
        "category": "SnapBack",
        "icon": "$(gear)"
      },
      {
        "command": "snapback.toggleOfflineMode",
        "title": "Toggle Offline Mode",
        "category": "SnapBack",
        "icon": "$(globe)"
      },
      {
        "command": "snapback.resetNotificationPreferences",
        "title": "Reset Notification Preferences",
        "category": "SnapBack",
        "icon": "$(bell-slash)"
      },
      {
        "comment": "═══════════════════════════════════════════════════════════════════════════════",
        "comment2": "Health & Risk Commands - File health monitoring",
        "comment3": "═══════════════════════════════════════════════════════════════════════════════"
      },
      {
        "command": "snapback.showFileHealthStatus",
        "title": "Show File Health Status",
        "category": "SnapBack",
        "icon": "$(pulse)"
      },
      {
        "command": "snapback.refreshFileHealthDecorations",
        "title": "Refresh File Health Decorations",
        "category": "SnapBack",
        "icon": "$(refresh)"
      },
      {
        "command": "snapback.clearFileHealthDecorations",
        "title": "Clear File Health Decorations",
        "category": "SnapBack",
        "icon": "$(clear-all)"
      },
      {
        "command": "snapback.getAuthState",
        "title": "Test: Get Auth State",
        "category": "SnapBack Test"
      },
      {
        "command": "snapback.test.getSnapshots",
        "title": "Test: Get Snapshots",
        "category": "SnapBack Test"
      },
      {
        "command": "snapback.test.restoreSnapshot",
        "title": "Test: Restore Snapshot",
        "category": "SnapBack Test"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "snapback",
          "title": "SnapBack",
          "icon": "media/activitybar-icon-24.png"
        }
      ]
    },
    "views": {
      "snapback": [
        {
          "id": "snapback.dashboard",
          "name": "SnapBack",
          "when": "snapback.isActive",
          "icon": "$(shield)"
        },
        {
          "id": "snapback.protectedFiles",
          "name": "Protected Files",
          "when": "snapback.isActive",
          "icon": "$(lock)"
        },
        {
          "id": "snapback.sessions",
          "name": "Sessions",
          "when": "snapback.isActive"
        },
        {
          "id": "snapback.explorer",
          "name": "SnapBack Cloud",
          "when": "snapback.isActive",
          "icon": "$(cloud)"
        }
      ]
    },
    "submenus": [
      {
        "id": "snapback.protectFile",
        "label": "SnapBack: Protect File"
      },
      {
        "id": "snapback.changeProtectionLevel",
        "label": "SnapBack: Change Protection Level"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "snapback.createSnapshot",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@1"
        },
        {
          "command": "snapback.snapBack",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@2"
        },
        {
          "submenu": "snapback.protectFile",
          "when": "snapback.isActive && !explorerResourceIsFolder && !snapback.isProtected",
          "group": "snapback@3"
        },
        {
          "submenu": "snapback.changeProtectionLevel",
          "when": "snapback.isActive && !explorerResourceIsFolder && snapback.isProtected",
          "group": "snapback@3"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "snapback.isActive && !explorerResourceIsFolder && snapback.isProtected",
          "group": "snapback@3"
        },
        {
          "command": "snapback.compareWithSnapshot",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@4"
        },
        {
          "command": "snapback.createPolicyOverride",
          "when": "snapback.isActive && !explorerResourceIsFolder",
          "group": "snapback@5"
        }
      ],
      "snapback.protectFile": [
        {
          "command": "snapback.setWatchLevel",
          "group": "levels@1",
          "when": "snapback.canProtect"
        },
        {
          "command": "snapback.setWarnLevel",
          "group": "levels@2",
          "when": "snapback.canProtect"
        },
        {
          "command": "snapback.setBlockLevel",
          "group": "levels@3",
          "when": "snapback.canProtect"
        }
      ],
      "snapback.changeProtectionLevel": [
        {
          "command": "snapback.setWatchLevel",
          "group": "levels@1",
          "when": "snapback.isProtected && snapback.currentLevel != 'watch'"
        },
        {
          "command": "snapback.setWarnLevel",
          "group": "levels@2",
          "when": "snapback.isProtected && snapback.currentLevel != 'warn'"
        },
        {
          "command": "snapback.setBlockLevel",
          "group": "levels@3",
          "when": "snapback.isProtected && snapback.currentLevel != 'block'"
        }
      ],
      "editor/context": [
        {
          "submenu": "snapback.protectFile",
          "when": "snapback.isActive && !snapback.isProtected",
          "group": "snapback@1"
        },
        {
          "submenu": "snapback.changeProtectionLevel",
          "when": "snapback.isActive && snapback.isProtected",
          "group": "snapback@1"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "snapback.isActive && snapback.isProtected",
          "group": "snapback@2"
        },
        {
          "command": "snapback.createSnapshot",
          "when": "snapback.isActive",
          "group": "snapback@3"
        },
        {
          "command": "snapback.createPolicyOverride",
          "when": "snapback.isActive",
          "group": "snapback@4"
        },
        {
          "command": "snapback.toggleOfflineMode",
          "when": "snapback.isActive",
          "group": "snapback@5"
        }
      ],
      "commandPalette": [
        {
          "command": "snapback.protectFile",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.protectCurrentFile",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.changeProtectionLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.setWatchLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.setWarnLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.setBlockLevel",
          "when": "snapback.isActive && editorFocus"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "snapback.isActive && snapback.fileProtected"
        },
        {
          "command": "snapback.compareWithSnapshot",
          "when": "snapback.isActive"
        },
        {
          "command": "snapback.openProtectedFile",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "snapback.openProtectedFile",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "navigation@1"
        },
        {
          "submenu": "snapback.changeProtectionLevel",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "protection@1"
        },
        {
          "command": "snapback.createSnapshot",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "snapshot@1",
          "icon": "$(save)"
        },
        {
          "command": "snapback.snapBack",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "snapshot@2",
          "icon": "$(history)"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "view == snapback.protectedFiles && viewItem == snapback.item.protectedFile",
          "group": "danger@1",
          "icon": "$(unlock)"
        },
        {
          "command": "snapback.unprotectFile",
          "when": "view == snapback.main && viewItem == snapback.item.protectedFile",
          "group": "danger@1",
          "icon": "$(unlock)"
        },
        {
          "command": "snapback.openSnapshotInWeb",
          "when": "view == snapbackExplorer && viewItem == snapshot",
          "group": "navigation@1",
          "icon": "$(link-external)"
        },
        {
          "command": "snapback.createSnapshot",
          "when": "view == snapbackExplorer && viewItem == blockingIssue",
          "group": "snapshot@1",
          "icon": "$(save)"
        }
      ],
      "view/title": [
        {
          "command": "snapback.showStatus",
          "when": "view == snapback.dashboard && snapback.protectionStatus == complete",
          "group": "navigation",
          "icon": "$(shield-check)"
        },
        {
          "command": "snapback.protectEntireRepo",
          "when": "view == snapback.dashboard && snapback.protectionStatus != complete",
          "group": "navigation"
        },
        {
          "command": "snapback.refreshViews",
          "when": "view == snapback.protectedFiles",
          "group": "navigation@1",
          "icon": "$(refresh)"
        },
        {
          "command": "snapback.showAllProtectedFiles",
          "when": "view == snapback.protectedFiles",
          "group": "navigation@2",
          "icon": "$(list-tree)"
        }
      ]
    },
    "configuration": {
      "title": "SnapBack",
      "properties": {
        "comment": "═══════════════════════════════════════════════════════════════════════════",
        "comment2": "Protection Settings - Default protection levels and visual indicators",
        "comment3": "═══════════════════════════════════════════════════════════════════════════",
        "snapback.protectionLevels.defaultLevel": {
          "type": "string",
          "enum": [
            "watch",
            "warn",
            "block"
          ],
          "enumDescriptions": [
            "Silent auto-snapshotting (recommended for most files)",
            "Confirmation before save (for important files)",
            "Required snapshot note (for critical files)"
          ],
          "default": "watch",
          "description": "Default protection level when protecting new files",
          "order": 1
        },
        "snapback.protectionLevels.showLevelBadges": {
          "type": "boolean",
          "default": true,
          "description": "Show protection level badges in file explorer",
          "order": 2
        },
        "snapback.showFileHealthDecorations": {
          "type": "boolean",
          "default": true,
          "description": "Show file health indicators (🛡/⚠️/🚨) based on detected risk",
          "order": 3
        },
        "comment4": "═══════════════════════════════════════════════════════════════════════════",
        "comment5": "Snapshot Settings - Snapshot behavior and management",
        "comment6": "═══════════════════════════════════════════════════════════════════════════",
        "snapback.snapshot.naming.useGit": {
          "type": "boolean",
          "default": true,
          "description": "Use git context for intelligent snapshot naming",
          "order": 10
        },
        "snapback.snapshot.naming.gitTimeout": {
          "type": "number",
          "default": 5000,
          "description": "Git command timeout in milliseconds",
          "minimum": 1000,
          "maximum": 30000,
          "order": 11
        },
        "snapback.snapshot.deduplication.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically replace duplicate snapshots with identical file states",
          "order": 12
        },
        "snapback.snapshot.deduplication.cacheSize": {
          "type": "number",
          "default": 500,
          "description": "Maximum number of snapshot hashes to cache for deduplication",
          "minimum": 100,
          "maximum": 10000,
          "order": 13
        },
        "snapback.snapshot.deletion.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before deleting snapshots",
          "order": 14
        },
        "snapback.snapshot.deletion.autoCleanup": {
          "type": "object",
          "default": {
            "enabled": false,
            "olderThanDays": 30,
            "keepProtected": true,
            "minimumSnapshots": 10
          },
          "description": "Automatic snapshot cleanup settings",
          "order": 15,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable automatic cleanup"
            },
            "olderThanDays": {
              "type": "number",
              "description": "Delete snapshots older than this many days",
              "minimum": 1
            },
            "keepProtected": {
              "type": "boolean",
              "description": "Keep protected snapshots even if old"
            },
            "minimumSnapshots": {
              "type": "number",
              "description": "Never delete below this count",
              "minimum": 0
            }
          }
        },
        "comment7": "═══════════════════════════════════════════════════════════════════════════",
        "comment8": "Notification Settings - User feedback and alerts",
        "comment9": "═══════════════════════════════════════════════════════════════════════════",
        "snapback.notifications.showSnapshotCreated": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when snapshots are created (Watch level only)",
          "order": 20
        },
        "snapback.notifications.duration": {
          "type": "number",
          "default": 3000,
          "description": "Duration to show snapshot notifications (milliseconds)",
          "order": 21
        },
        "snapback.notifications.showConfigSync": {
          "type": "boolean",
          "default": false,
          "description": "Show notifications when .snapbackrc protection rules are loaded (silent by default)",
          "order": 22
        },
        "snapback.showAutoSnapshotNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when auto-snapshots are created for protected files",
          "order": 23
        },
        "comment10": "═══════════════════════════════════════════════════════════════════════════",
        "comment11": "Guardian (AI Protection) - Risk detection and prevention",
        "comment12": "═══════════════════════════════════════════════════════════════════════════",
        "snapback.guardian.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable SnapBack Guardian AI detection and protection",
          "order": 30
        },
        "snapback.guardian.protectionLevel": {
          "type": "string",
          "enum": [
            "none",
            "warn",
            "block"
          ],
          "default": "warn",
          "description": "Protection level for AI-generated code",
          "order": 31
        },
        "snapback.guardian.plugins.secretDetection": {
          "type": "boolean",
          "default": true,
          "description": "Enable secret detection plugin",
          "order": 32
        },
        "snapback.guardian.plugins.mockReplacement": {
          "type": "boolean",
          "default": true,
          "description": "Enable mock replacement detection plugin",
          "order": 33
        },
        "snapback.guardian.plugins.phantomDependency": {
          "type": "boolean",
          "default": true,
          "description": "Enable phantom dependency detection plugin",
          "order": 34
        },
        "snapback.guardian.thresholds.warn": {
          "type": "number",
          "default": 6,
          "description": "Risk score threshold for warnings (0-10 scale)",
          "order": 35
        },
        "snapback.guardian.thresholds.block": {
          "type": "number",
          "default": 8,
          "description": "Risk score threshold for blocking changes (0-10 scale)",
          "order": 36
        },
        "comment13": "═══════════════════════════════════════════════════════════════════════════",
        "comment14": "AI Detection - Session and change detection",
        "comment15": "═══════════════════════════════════════════════════════════════════════════",
        "snapback.aiDetection.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI detection and session tracking",
          "order": 40
        },
        "snapback.aiDetection.showSessionBadge": {
          "type": "boolean",
          "default": true,
          "description": "Show AI detection result badge in status bar",
          "order": 41
        },
        "snapback.aiDetection.confidenceThreshold": {
          "type": "number",
          "default": 6,
          "minimum": 0,
          "maximum": 10,
          "description": "Confidence threshold for showing AI detection results (0-10 scale)",
          "order": 42
        },
        "comment16": "═══════════════════════════════════════════════════════════════════════════",
        "comment17": "API & Authentication - Connection and authentication settings",
        "comment18": "═══════════════════════════════════════════════════════════════════════════",
